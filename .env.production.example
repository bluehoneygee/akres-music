# Production environment.
# Fill these values in GitHub Environment `production` and Vercel Production env.
# Do not commit a real `.env.production`.

MONGODB_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGODB_DB=akres-music-production

AUTH_SECRET=replace-with-a-long-random-secret
AUTH_URL=https://akres-music.example.com
CRON_SECRET=replace-with-a-long-random-secret

# GitHub Actions deployment secrets.
VERCEL_TOKEN=replace-with-vercel-token
VERCEL_ORG_ID=replace-with-vercel-org-id
VERCEL_PROJECT_ID=replace-with-vercel-project-id
